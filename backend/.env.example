# Copy this file to backend/.env and fill in real values.
# `backend/.env` is gitignored — it will never be committed.

# ── Supabase Auth (required) ────────────────────────────────────────
# Find these at: Supabase dashboard → Project Settings → API
# - SUPABASE_JWT_SECRET is the "JWT Secret" — used server-side to verify
#   incoming bearer tokens. NOT the anon key. Keep secret.
SUPABASE_JWT_SECRET=
SUPABASE_PROJECT_URL=
# VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_0lRv6M0VrnLCgAU1DRwjbg_dlrj7zSz

# Set to "1" to bypass JWT verification (dev only — treats every request as
# an admin user). Leave unset in any non-local environment.
# SUPABASE_AUTH_DISABLED=0

# ── Groq (live LLM replies) ─────────────────────────────────────────
# Free API key — sign up at https://console.groq.com (no credit card).
# Without this set, ResolveAI falls back to template-based replies.
GROQ_API_KEY=


# Optional overrides:
# GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_TIMEOUT=15

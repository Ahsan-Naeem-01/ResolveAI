# Copy this file to backend/.env and fill in your real key.
# `backend/.env` is gitignored — it will never be committed.

# ── Groq (live LLM replies) ─────────────────────────────────────────
# Free API key — sign up at https://console.groq.com (no credit card).
# Without this set, ResolveAI falls back to template-based replies.
GROQ_API_KEY=

# Optional overrides:
# GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_TIMEOUT=15

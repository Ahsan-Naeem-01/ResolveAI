# Copy this file to backend/.env and fill in real values.
# `backend/.env` is gitignored — it will never be committed.

# ── Database (optional locally, REQUIRED in production) ─────────────
# Local dev: leave blank — the app uses SQLite at backend/resolveai.db.
# Production (Render): paste the Supabase / Neon / Render Postgres
# connection string here. URLs starting with `postgres://` are auto-
# rewritten to `postgresql+psycopg2://`.
DATABASE_URL=

# ── CORS (production only) ──────────────────────────────────────────
# Comma-separated list of origins allowed to call the API. Leave blank
# locally; set to your Vercel URL in Render's env-var panel.
# Example: FRONTEND_ORIGIN=https://resolveai.vercel.app
FRONTEND_ORIGIN=

# ── Supabase Auth (required) ────────────────────────────────────────
# Find these at: Supabase dashboard → Project Settings → API
#
# SUPABASE_PROJECT_URL  — REQUIRED for new projects (Supabase rotated to
#   asymmetric ES256 JWT Signing Keys). The backend fetches the public key
#   from <PROJECT_URL>/auth/v1/.well-known/jwks.json to verify tokens.
SUPABASE_PROJECT_URL=
#
# SUPABASE_JWT_SECRET   — only needed if your project still issues legacy
#   HS256-signed tokens. New Supabase projects do NOT use this — leave blank.
#   (Project Settings → API → "JWT Settings" → "Legacy JWT Secret")
SUPABASE_JWT_SECRET=
# VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_0lRv6M0VrnLCgAU1DRwjbg_dlrj7zSz

# Set to "1" to bypass JWT verification (dev only — treats every request as
# an admin user). Leave unset in any non-local environment.
# SUPABASE_AUTH_DISABLED=0

# ── Groq (live LLM replies) ─────────────────────────────────────────
# Free API key — sign up at https://console.groq.com (no credit card).
# Without this set, ResolveAI falls back to template-based replies.
GROQ_API_KEY=


# Optional overrides:
# GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_TIMEOUT=15

# Copy to frontend-vite/.env and fill in your Supabase project values.
# Find these at: Supabase dashboard → Project Settings → API
#
# These two values are sent to the browser — that is normal and safe.
# Supabase enforces auth via the row-level JWT signature, not via secrecy
# of the anon key.

VITE_SUPABASE_ANON_KEY=
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# ── API base URL ───────────────────────────────────────────────────
# Where the React app should send /api/* requests.
#
# LOCAL DEV: leave BLANK. Vite proxies /api → http://localhost:8000
#            (see vite.config.js).
#
# VERCEL (production): set this in Vercel → Project → Settings → Environment
# Variables to your Render backend URL, e.g.
#     VITE_API_BASE_URL=https://resolveai-backend.onrender.com
VITE_API_BASE_URL=
